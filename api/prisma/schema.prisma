model app_config {
  key        String    @id
  value      Json
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model coal_provider_manufacturer_inquiries {
  id                     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coal_provider_id       String       @db.Uuid
  manufacturer_id        String       @db.Uuid
  product_id             String?      @db.Uuid
  inquiry_type           String       @default("coal_supply") @db.VarChar(50)
  message                String
  coal_type              String?      @db.VarChar(100)
  quantity               Int?
  unit                   String?      @db.VarChar(20)
  delivery_location      String?
  expected_delivery_date DateTime?    @db.Date
  price_per_unit         Decimal?     @db.Decimal(10, 2)
  status                 String?      @default("pending") @db.VarChar(20)
  created_at             DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?    @default(now()) @db.Timestamptz(6)
  coal_providers         CoalProvider @relation(fields: [coal_provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  manufacturers          Manufacturer @relation(fields: [manufacturer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products               products?    @relation(fields: [product_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
