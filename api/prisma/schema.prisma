generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Manufacturer {
  id                                        String                                      @id(map: "customers_pkey1") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                      String
  email                                     String                                      @unique(map: "customers_email_key")
  phone                                     String
  company_name                              String                                      @map("company_name")
  state                                     String
  district                                  String
  kiln_type                                 String                                      @map("kiln_type")
  additional_info                           String?                                     @map("additional_info")
  interested_in_exclusive_services          Boolean?                                    @default(false) @map("interested_in_exclusive_services")
  joined_date                               DateTime?                                   @default(now()) @map("joined_date") @db.Timestamptz(6)
  is_test_entry                             Boolean?                                    @default(false) @map("is_test_entry")
  created_at                                DateTime?                                   @default(now()) @map("created_at") @db.Timestamptz(6)
  status                                    String                                      @default("waitlist")
  city                                      String?
  country                                   String?                                     @default("India")
  biz_gst                                   String?                                     @map("biz_gst")
  exim_code                                 String?                                     @map("exim_code")
  pan_no                                    String?                                     @map("pan_no")
  pincode                                   String?
  interested_in_industry_quiz               Boolean?                                    @default(false) @map("interested_in_industry_quiz")
  updated_at                                DateTime?                                   @default(now()) @map("updated_at") @db.Timestamptz(6)
  latitude                                  Float?
  longitude                                 Float?
  category                                  String?                                     @default("manufacturer")
  is_featured                               Boolean                                     @default(false) @map("is_featured")
  is_verified                               Boolean                                     @default(false) @map("is_verified")
  country_code                              String?                                     @default("+91") @map("country_code")
  coal_provider_manufacturer_inquiries      coal_provider_manufacturer_inquiries[]
  coal_provider_manufacturer_ratings        coal_provider_manufacturer_ratings[]
  inquiries                                 inquiries[]
  inquiry_response_history                  inquiry_response_history[]
  manufacturer_coal_inquiries               manufacturer_coal_inquiries[]
  manufacturer_coal_orders                  manufacturer_coal_orders[]
  manufacturer_coal_quotations              manufacturer_coal_quotations[]
  manufacturer_coal_ratings                 manufacturer_coal_ratings[]
  manufacturer_transport_inquiries          manufacturer_transport_inquiries[]
  manufacturer_transport_orders             manufacturer_transport_orders[]
  manufacturer_transport_quotations         manufacturer_transport_quotations[]
  manufacturer_transport_ratings            manufacturer_transport_ratings[]
  products                                  products[]
  quotations                                quotations[]
  sample_orders                             sample_orders[]
  transport_provider_manufacturer_inquiries transport_provider_manufacturer_inquiries[]
  transport_provider_manufacturer_ratings   transport_provider_manufacturer_ratings[]

  @@index([category], map: "idx_manufacturers_category")
  @@index([country_code], map: "idx_manufacturers_country_code")
  @@index([is_verified], map: "idx_manufacturers_is_verified")
  @@index([phone], map: "idx_manufacturers_phone")
  @@map("manufacturers")
}

model Endcustomer {
  id             String           @id(map: "customers_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  email          String?
  company_name   String?          @map("company_name")
  state          String?
  district       String?
  city           String?
  pin_code       String?          @map("pin_code")
  country        String?
  gst_details    String?          @map("gst_details")
  created_at     DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  vatno          String?
  panno          String?
  phone          String?
  address        String?
  latitude       Float?
  longitude      Float?
  category       String?          @default("end_buyer")
  deleted_at     DateTime?        @map("deleted_at") @db.Timestamptz(6)
  customers_auth customers_auth[]
  inquiries      inquiries[]
  orders         orders[]
  quotations     quotations[]
  sample_orders  sample_orders[]

  @@index([category], map: "idx_endcustomers_category")
  @@map("endcustomers")
}

model CoalProvider {
  id                                   String                                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                 String
  email                                String
  phone                                String                                 @unique
  country                              String                                 @default("India")
  company_name                         String                                 @map("company_name")
  state                                String
  district                             String
  city                                 String
  pincode                              String
  supply_capacity                      String?                                @map("supply_capacity")
  exim_code                            String?                                @map("exim_code")
  pan_no                               String?                                @map("pan_no")
  biz_gst                              String?                                @map("biz_gst")
  additional_info                      String?                                @map("additional_info")
  created_at                           DateTime?                              @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at                           DateTime?                              @default(now()) @map("updated_at") @db.Timestamptz(6)
  delivery_service_area                String?                                @map("delivery_service_area")
  category                             String?                                @default("coal_provider")
  fuel_types                           String[]                               @map("fuel_types")
  country_code                         String?                                @default("+91") @map("country_code")
  coal_provider_manufacturer_inquiries coal_provider_manufacturer_inquiries[]
  coal_provider_manufacturer_ratings   coal_provider_manufacturer_ratings[]
  inquiry_response_history             inquiry_response_history[]
  manufacturer_coal_inquiries          manufacturer_coal_inquiries[]
  manufacturer_coal_orders             manufacturer_coal_orders[]
  manufacturer_coal_quotations         manufacturer_coal_quotations[]
  manufacturer_coal_ratings            manufacturer_coal_ratings[]

  @@index([category], map: "idx_coal_providers_category")
  @@index([state, district, city], map: "idx_coal_providers_location")
  @@index([phone], map: "idx_coal_providers_phone")
  @@map("coal_providers")
}

model TransportProvider {
  id                                        String                                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                      String
  email                                     String
  phone                                     String                                      @unique
  company_name                              String                                      @map("company_name")
  country                                   String                                      @default("India")
  state                                     String
  district                                  String
  city                                      String
  pincode                                   String
  transport_type                            String                                      @map("transport_type")
  vehicle_capacity                          String?                                     @map("vehicle_capacity")
  service_area                              String                                      @map("service_area")
  biz_gst                                   String?                                     @map("biz_gst")
  pan_no                                    String?                                     @map("pan_no")
  exim_code                                 String?                                     @map("exim_code")
  additional_info                           String?                                     @map("additional_info")
  created_at                                DateTime?                                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at                                DateTime?                                   @default(now()) @map("updated_at") @db.Timestamptz(6)
  category                                  String?                                     @default("transport_provider")
  country_code                              String?                                     @default("+91") @map("country_code") @db.VarChar(10)
  transport_types                           String[]                                    @map("transport_types")
  manufacturer_transport_inquiries          manufacturer_transport_inquiries[]
  manufacturer_transport_orders             manufacturer_transport_orders[]
  manufacturer_transport_quotations         manufacturer_transport_quotations[]
  manufacturer_transport_ratings            manufacturer_transport_ratings[]
  transport_provider_manufacturer_inquiries transport_provider_manufacturer_inquiries[]
  transport_provider_manufacturer_ratings   transport_provider_manufacturer_ratings[]

  @@index([category], map: "idx_transport_providers_category")
  @@index([city], map: "idx_transport_providers_city")
  @@index([email], map: "idx_transport_providers_email")
  @@index([phone], map: "idx_transport_providers_phone")
  @@index([state], map: "idx_transport_providers_state")
  @@map("transport_providers")
}

model LabourContractor {
  id                          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                        String
  email                       String
  phone                       String                        @unique
  company_name                String                        @map("company_name")
  country                     String                        @default("India")
  category                    String                        @default("labour_contractor")
  state                       String
  district                    String
  city                        String
  pincode                     String
  service_types               String[]                      @map("service_types")
  experience_years            String                        @map("experience_years")
  service_area                String                        @map("service_area")
  additional_info             String?                       @map("additional_info")
  biz_gst                     String?                       @map("biz_gst")
  pan_no                      String?                       @map("pan_no")
  exim_code                   String?                       @map("exim_code")
  latitude                    Decimal?                      @db.Decimal(10, 8)
  longitude                   Decimal?                      @db.Decimal(11, 8)
  is_active                   Boolean?                      @default(true) @map("is_active")
  created_at                  DateTime?                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at                  DateTime?                     @default(now()) @map("updated_at") @db.Timestamptz(6)
  aadhar_no                   String?                       @map("aadhar_no")
  labour_contractor_inquiries labour_contractor_inquiries[]
  labour_contractor_projects  labour_contractor_projects[]
  labour_contractor_ratings   labour_contractor_ratings[]

  @@index([category], map: "idx_labour_contractors_category")
  @@index([country], map: "idx_labour_contractors_country")
  @@index([phone], map: "idx_labour_contractors_phone")
  @@index([service_types], map: "idx_labour_contractors_service_types", type: Gin)
  @@index([state], map: "idx_labour_contractors_state")
  @@map("labour_contractors")
}

