model fraud_reports {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  reporter_phone        String
  reporter_country_code String?  @default("+91")
  reporter_verified     Boolean  @default(false)
  category              String?
  title                 String
  description           String?
  state                 String?
  district              String?
  city                  String?
  attachments           String[] @default([])
  status                String?  @default("pending")
  source                String?
  latitude              String?
  longitude             String?
  reporter_name         String?
  company_name          String?
  user_category         String?
  country               String?

  @@index([category], map: "idx_fraud_reports_category")
  @@index([created_at(sort: Desc)], map: "idx_fraud_reports_created_at")
  @@index([state, district, city], map: "idx_fraud_reports_location")
}

model inquiries {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id       String              @db.Uuid
  manufacturer_id   String              @db.Uuid
  subject           String
  message           String
  status            String              @default("pending")
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  endcustomers      Endcustomer         @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  manufacturers     Manufacturer        @relation(fields: [manufacturer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inquiry_responses inquiry_responses[]
}

model inquiry_response_history {
  id                          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inquiry_id                  String                      @db.Uuid
  coal_provider_id            String                      @db.Uuid
  manufacturer_id             String                      @db.Uuid
  response_text               String
  response_type               String?                     @default("text_response") @db.VarChar(50)
  response_number             Int                         @default(1)
  responded_by                String?                     @db.VarChar(100)
  is_current_response         Boolean?                    @default(true)
  created_at                  DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime?                   @default(now()) @db.Timestamptz(6)
  coal_providers              CoalProvider                @relation(fields: [coal_provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  manufacturer_coal_inquiries manufacturer_coal_inquiries @relation(fields: [inquiry_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  manufacturers               Manufacturer                @relation(fields: [manufacturer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([coal_provider_id], map: "idx_inquiry_response_history_coal_provider_id")
  @@index([inquiry_id], map: "idx_inquiry_response_history_inquiry_id")
  @@index([is_current_response], map: "idx_inquiry_response_history_is_current")
  @@index([manufacturer_id], map: "idx_inquiry_response_history_manufacturer_id")
}

model inquiry_responses {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inquiry_id      String    @db.Uuid
  response_text   String
  created_by      String    @db.Uuid
  created_by_name String?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  inquiries       inquiries @relation(fields: [inquiry_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

