  id                     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manufacturer_id        String       @db.Uuid
  coal_provider_id       String       @db.Uuid
  rating                 Int
  review_title           String?      @db.VarChar(200)
