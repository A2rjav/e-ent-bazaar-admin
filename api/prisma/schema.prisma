model downloadable_resources {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String    @db.VarChar(500)
  description    String?
  file_name      String    @db.VarChar(500)
  file_url       String
  file_type      String    @db.VarChar(100)
