  manufacturers          Manufacturer @relation(fields: [manufacturer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model customers {
  id                               String    @id(map: "customers_pkey2") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                             String
